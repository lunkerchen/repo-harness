            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "encoding": {
            "enum": [
              "utf-8",
              "base64"
            ]
          },
          "expected_sha256": {
            "type": "string"
          },
          "must_not_exist": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
