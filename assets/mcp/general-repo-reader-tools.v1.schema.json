      "description": "Create or replace one repo-relative file in a read_write repo using revision preconditions and atomic same-directory rename.",
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": true,
        "idempotentHint": false,
        "openWorldHint": false
      },
      "input_schema": {
        "type": "object",
        "required": [
          "repo_id",
          "path",
