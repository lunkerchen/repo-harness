                "type": "string"
              },
              "ignore_digest": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "mutation_id": {
                "type": "string"
              },
              "before": {
                "type": "object"
              },
              "after": {
                "type": "object"
              },
              "diff": {
                "type": "object"
              },
              "patch": {
                "type": "object"
              },
              "index_state": {
                "type": "string"
              }
            },
            "additionalProperties": true
          },
          {
            "type": "object",
            "required": [
              "error"
            ],
            "properties": {
              "error": {
                "type": "object",
                "required": [
                  "code",
                  "message",
                  "retryable"
                ],
                "properties": {
                  "code": {
                    "type": "string"
                  },
                  "message": {
                    "type": "string"
                  },
                  "retryable": {
                    "type": "boolean"
                  },
