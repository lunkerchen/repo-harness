    {
      "name": "apply_patch",
      "description": "Apply structured text edits or a guarded unified diff to one existing repo-relative file using an expected_sha256 precondition.",
      "annotations": {
        "readOnlyHint": false,
        "destructiveHint": true,
        "idempotentHint": false,
        "openWorldHint": false
      },
      "input_schema": {
        "type": "object",
        "required": [
          "repo_id",
          "path",
          "expected_sha256"
        ],
        "properties": {
          "repo_id": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "expected_sha256": {
            "type": "string"
          },
          "edits": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "old_text",
                "new_text"
              ],
              "properties": {
                "old_text": {
                  "type": "string"
                },
                "new_text": {
                  "type": "string"
                },
                "occurrence": {
                  "type": "number"
                }
              },
              "additionalProperties": false
            }
          },
          "unified_diff": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
