{
  "version": "1.0.0",
  "contractId": "tasks-first-harness-v1",
  "compatibility": {
    "agents": [
      "claude",
      "codex"
    ],
    "repoLocalFirst": true
  },
  "externalTooling": {
    "waza": {
      "sourceRepo": "tw93/Waza",
      "managedSkills": [
        "think",
        "hunt",
        "check",
        "health"
      ],
      "primaryHost": "codex",
      "codexPrimaryPath": "~/.codex/skills",
      "stagingCachePath": "~/.agents/skills",
      "syncMode": "stage-upstream-then-copy-to-codex",
      "hostDriftPolicy": "report-per-host-version-staging-and-upstream-drift"
    },
    "codexAutomationProfile": {
      "requiredSkills": [
        "health",
        "check",
        "mermaid"
      ],
      "optionalSkills": [],
      "mode": "codex-runtime-reference",
      "source": "~/.codex/skills",
      "routes": {
        "workflowHealth": "waza:health",
        "reviewGate": "waza:check",
        "architectureDiagram": "mermaid"
      },
      "vendoringPolicy": "do-not-vendor-skill-body"
    },
    "diagramDesign": {
      "skillName": "mermaid",
      "primaryHost": "codex",
      "codexPrimaryPath": "~/.codex/skills/mermaid",
      "syncMode": "external-installed-skill",
      "vendoringPolicy": "do-not-vendor"
    }
  },
  "agenticDevelopment": {
    "routing": {
      "productDiscovery": "gstack:office-hours",
      "complexEngineeringPlan": "gstack:plan-eng-review",
      "designPlan": "gstack:plan-design-review",
      "smallOrMediumPlan": "waza:think",
      "bugOrRegression": "waza:hunt",
      "postImplementationReview": "waza:check"
    },
    "dueDiligence": {
      "levels": [
        "P1_GLOBAL_ARCHITECTURE",
        "P2_DATA_FLOW_TRACE",
        "P3_DESIGN_DECISION"
      ],
      "explicitReportRequiredFor": [
        "plan-eng-review",
        "hunt",
        "risky_refactor",
        "deployment",
        "auth_payment_data",
        "shared_contract"
      ]
    }
  },
  "helpers": {
    "scripts": [
      "new-spec.sh",
      "new-sprint.sh",
      "new-plan.sh",
      "capture-plan.sh",
      "plan-to-todo.sh",
      "contract-worktree.sh",
      "ship-worktrees.sh",
      "archive-workflow.sh",
      "refresh-current-status.sh",
      "prepare-handoff.sh",
      "verify-contract.sh",
      "summarize-failures.sh",
      "verify-sprint.sh",
      "sprint-backlog.sh",
      "check-task-sync.sh",
      "check-deploy-sql-order.sh",
      "check-architecture-sync.sh",
      "check-agent-tooling.sh",
      "check-context-files.sh",
      "check-brain-manifest.sh",
      "sync-brain-docs.sh",
      "check-skill-version.ts",
      "select-agent-context-blocks.sh",
      "ensure-task-workflow.sh",
      "check-task-workflow.sh",
      "maintenance-triage.sh",
      "switch-plan.sh",
      "workflow-contract.ts",
      "inspect-project-state.ts",
      "migrate-workflow-docs.ts",
      "migrate-project-template.sh",
      "context-budget.ts",
      "capability-resolver.ts",
      "architecture-event.ts",
      "capability-config.ts",
      "architecture-queue.sh",
      "archive-architecture-request.sh",
      "context-contract-sync.sh",
      "workstream-sync.sh",
      "prepare-codex-handoff.sh",
      "codex-handoff-resume.sh"
    ]
  },
  "artifacts": {
    "runtimeManifest": ".ai/harness/workflow-contract.json",
    "requiredDirectories": [
      "plans",
      "plans/archive",
      "tasks",
      "tasks/archive",
      "tasks/contracts",
      "tasks/reviews",
      "tasks/notes",
      "tasks/workstreams",
      ".claude/templates",
      ".ai/context",
      ".ai/harness",
      ".ai/harness/checks",
      ".ai/harness/failures",
      ".ai/harness/handoff",
      ".ai/harness/context-budget",
      ".ai/harness/security",
      ".ai/harness/planning",
      ".ai/harness/architecture",
      ".ai/harness/worktrees",
      ".ai/harness/runs",
      "docs/architecture",
      "docs/architecture/domains",
      "docs/architecture/modules",
      "docs/architecture/requests",
      "docs/architecture/snapshots",
      "docs/architecture/diagrams",
      "docs/reference-configs",
      "deploy",
      "deploy/env",
      "deploy/scripts",
      "deploy/submissions",
      "deploy/runbooks",
      "deploy/release-checklists",
      "deploy/sql"
    ],
    "requiredFiles": [
      "docs/spec.md",
      ".claude/templates/spec.template.md",
      ".claude/templates/plan.template.md",
      ".claude/templates/research.template.md",
      ".claude/templates/contract.template.md",
      ".claude/templates/review.template.md",
      ".claude/templates/implementation-notes.template.md",
      "scripts/new-spec.sh",
      "scripts/new-sprint.sh",
      "scripts/new-plan.sh",
      "scripts/capture-plan.sh",
      "scripts/plan-to-todo.sh",
      "scripts/contract-worktree.sh",
      "scripts/ship-worktrees.sh",
      "scripts/archive-workflow.sh",
      "scripts/refresh-current-status.sh",
      "scripts/prepare-handoff.sh",
      "scripts/verify-contract.sh",
      "scripts/summarize-failures.sh",
      "scripts/verify-sprint.sh",
      "scripts/sprint-backlog.sh",
      "scripts/check-task-sync.sh",
      "scripts/check-deploy-sql-order.sh",
      "scripts/check-architecture-sync.sh",
      "scripts/check-agent-tooling.sh",
      "scripts/check-context-files.sh",
      "scripts/sync-brain-docs.sh",
      "scripts/check-skill-version.ts",
      "scripts/select-agent-context-blocks.sh",
      "scripts/ensure-task-workflow.sh",
      "scripts/check-task-workflow.sh",
      "scripts/maintenance-triage.sh",
      "scripts/switch-plan.sh",
      "scripts/workflow-contract.ts",
      "scripts/inspect-project-state.ts",
      "scripts/migrate-workflow-docs.ts",
      "scripts/migrate-project-template.sh",
      "scripts/context-budget.ts",
      "scripts/capability-resolver.ts",
      "scripts/architecture-event.ts",
      "scripts/capability-config.ts",
      "scripts/architecture-queue.sh",
      "scripts/archive-architecture-request.sh",
      "scripts/context-contract-sync.sh",
      "scripts/workstream-sync.sh",
      "scripts/prepare-codex-handoff.sh",
      "scripts/codex-handoff-resume.sh",
      "tasks/current.md",
      "tasks/todo.md",
      "tasks/lessons.md",
      "tasks/research.md",
      "docs/architecture/index.md",
      ".ai/context/context-map.json",
      ".ai/context/capabilities.json",
      ".ai/context/capability-source-map.json",
      ".ai/harness/policy.json",
      ".ai/harness/brain-manifest.json",
      ".ai/harness/workflow-contract.json",
      "docs/reference-configs/harness-overview.md",
      "docs/reference-configs/agentic-development-flow.md",
      "docs/reference-configs/external-tooling.md",
      "docs/reference-configs/sprint-contracts.md",
      "docs/reference-configs/handoff-protocol.md",
      "docs/reference-configs/document-generation.md",
      "docs/reference-configs/global-working-rules.md",
      "deploy/README.md"
    ],
    "runtimeFiles": [
      ".ai/harness/checks/latest.json",
      ".ai/harness/checks/post-bash-latest.json",
      ".ai/harness/events.jsonl",
      ".ai/harness/archive/",
      ".ai/harness/failures/latest.jsonl",
      ".ai/harness/handoff/current.md",
      ".ai/harness/handoff/resume.md",
      ".ai/harness/context-budget/latest.json",
      ".ai/harness/capability-context/",
      ".ai/harness/security/.gitkeep",
      ".ai/harness/planning/",
      ".ai/harness/architecture/events.jsonl",
      ".ai/harness/active-plan",
      ".ai/harness/active-worktree",
      ".ai/harness/sprint/",
      ".ai/harness/worktrees/",
      ".ai/harness/runs/.gitkeep"
    ]
  },
  "documents": {
    "spec": "docs/spec.md",
    "planDirectory": "plans",
    "deferredGoalLedger": "tasks/todo.md",
    "researchNotes": "tasks/research.md",
    "implementationNotesDirectory": "tasks/notes",
    "lessonsLog": "tasks/lessons.md"
  },
  "migrations": {
    "legacyVersions": [
      "pre-tasks-first",
      "tasks-first-without-contract-manifest",
      "current-v1"
    ],
    "legacyPaths": [
      "docs/plan.md",
      "docs/TODO.md",
      "docs/PROGRESS.md",
      "docs/contract.md",
      "docs/review.md",
      "docs/handoff.md",
      "HANDOFF.md"
    ],
    "upgrade": {
      "strategyVersion": 1,
      "supportedLegacyVersions": [
        "pre-tasks-first",
        "tasks-first-without-contract-manifest",
        "current-v1"
      ],
      "actionClasses": [
        "preserve",
        "archive",
        "reconfigure",
        "remove"
      ],
      "safety": {
        "removeOnlyOwnership": "known_generated",
        "unknownFiles": "preserve-or-archive",
        "customHooks": "preserve",
        "ignoredReferenceMaterial": "preserve",
        "localSecrets": "preserve"
      },
      "actions": [
        {
          "id": "legacy-docs-plan",
          "signal": "legacy-docs-plan",
          "action": "archive",
          "risk": "low",
          "ownership": "user_authored",
          "paths": [
            "docs/plan.md"
          ],
          "targetPaths": [
            "plans/archive/legacy-docs-plan.md"
          ],
          "summary": "Archive the legacy plan document before refreshing the tasks-first workflow."
        },
        {
          "id": "legacy-docs-todo",
          "signal": "legacy-docs-todo",
          "action": "archive",
          "risk": "low",
          "ownership": "user_authored",
          "paths": [
            "docs/TODO.md"
          ],
          "targetPaths": [
            "tasks/archive/legacy-docs-TODO.md"
          ],
          "summary": "Archive the legacy checklist before writing the active task projection."
        },
        {
          "id": "legacy-docs-progress",
          "signal": "legacy-docs-progress",
          "action": "archive",
          "risk": "medium",
          "ownership": "user_authored",
          "paths": [
            "docs/PROGRESS.md"
          ],
          "targetPaths": [
            "tasks/research.md",
            "tasks/archive/legacy-docs-PROGRESS.md"
          ],
          "summary": "Move execution-log style progress content into research/archive surfaces."
        },
        {
          "id": "legacy-task-checklist-format",
          "signal": "legacy-task-checklist-format",
          "action": "archive",
          "risk": "medium",
          "ownership": "user_authored",
          "paths": [
            "tasks/todo.md"
          ],
          "targetPaths": [
            "tasks/archive/legacy-tasks-todo.md"
          ],
          "summary": "Archive old task checklists before rewriting tasks/todo.md as the active execution projection."
        },
        {
          "id": "runtime-contract-refresh",
          "signal": "missing-runtime-contract-manifest",
          "action": "reconfigure",
          "risk": "low",
          "ownership": "managed_config",
          "paths": [
            ".ai/harness/workflow-contract.json",
            ".ai/harness/policy.json",
            ".ai/context/context-map.json"
          ],
          "summary": "Install the current runtime workflow contract, harness policy, and context map."
        },
        {
          "id": "policy-upgrade-strategy-refresh",
          "signal": "policy-missing-upgrade-strategy",
          "action": "reconfigure",
          "risk": "low",
          "ownership": "managed_config",
          "paths": [
            ".ai/harness/policy.json"
          ],
          "summary": "Merge the versioned upgrade strategy into the harness policy without overwriting explicit repo overrides."
        },
        {
          "id": "legacy-skill-factory-generated-assets",
          "signal": "legacy-skill-factory-surface",
          "action": "remove",
          "risk": "medium",
          "ownership": "known_generated",
          "paths": [
            "scripts/skill-factory-check.sh",
            "scripts/skill-factory-create.sh",
            ".ai/hooks/lib/memory-state.sh",
            ".ai/hooks/lib/skill-factory.sh",
            ".ai/hooks/memory-intake.sh",
            ".ai/hooks/skill-factory-session-end.sh",
            ".claude/skill-factory",
            ".claude/.memory-context.json",
            ".claude/.memory-snapshot.json",
            ".claude/.skill-factory-state.json",
            ".claude/.skill-factory-session.json",
            ".claude/.skill-factory-session-marker.json",
            ".claude/.skill-factory-user"
          ],
          "summary": "Remove repo-local Skill Factory and auto-memory files that were generated by retired workflow versions."
        },
        {
          "id": "legacy-claude-hook-shims",
          "signal": "stale-generated-claude-hook-shims",
          "action": "remove",
          "risk": "medium",
          "ownership": "known_generated",
          "paths": [
            ".claude/hooks/anti-simplification.sh",
            ".claude/hooks/atomic-commit.sh",
            ".claude/hooks/atomic-pending.sh",
            ".claude/hooks/changelog-guard.sh",
            ".claude/hooks/context-pressure-hook.sh",
            ".claude/hooks/finalize-handoff.sh",
            ".claude/hooks/hook-input.sh",
            ".claude/hooks/lib/memory-state.sh",
            ".claude/hooks/lib/session-state.sh",
            ".claude/hooks/lib/skill-factory.sh",
            ".claude/hooks/lib/workflow-state.sh",
            ".claude/hooks/memory-intake.sh",
            ".claude/hooks/post-bash.sh",
            ".claude/hooks/post-edit-guard.sh",
            ".claude/hooks/pre-code-change.sh",
            ".claude/hooks/pre-edit-guard.sh",
            ".claude/hooks/prompt-guard.sh",
            ".claude/hooks/run-hook.sh",
            ".claude/hooks/session-start-context.sh",
            ".claude/hooks/skill-factory-session-end.sh",
            ".claude/hooks/tdd-guard-hook.sh",
            ".claude/hooks/trace-event.sh",
            ".claude/hooks/worktree-guard.sh"
          ],
          "summary": "Remove generated Claude hook shims after .ai/hooks becomes the shared hook implementation layer."
        },
        {
          "id": "split-post-tool-observer-hooks",
          "signal": "stale-split-post-tool-hooks",
          "action": "remove",
          "risk": "low",
          "ownership": "known_generated",
          "paths": [
            ".ai/hooks/trace-event.sh",
            ".ai/hooks/context-pressure-hook.sh"
          ],
          "summary": "Remove the split PostToolUse observer hooks replaced by the merged post-tool-observer.sh."
        },
        {
          "id": "legacy-architecture-drift-helper",
          "signal": "stale-architecture-drift-helper",
          "action": "remove",
          "risk": "low",
          "ownership": "known_generated",
          "paths": [
            "scripts/architecture-drift.sh",
            "assets/templates/helpers/architecture-drift.sh"
          ],
          "summary": "Remove the retired architecture-drift helper after architecture-queue.sh absorbs request, card, index, and gate ownership."
        },
        {
          "id": "custom-claude-hooks-preserve",
          "signal": "custom-claude-hooks",
          "action": "preserve",
          "risk": "low",
          "ownership": "user_authored",
          "paths": [
            ".claude/hooks/custom-*.sh"
          ],
          "summary": "Preserve user-owned Claude hook scripts and keep them merged through .claude/settings.json."
        },
        {
          "id": "reference-and-secret-surfaces-preserve",
          "signal": "ignored-reference-or-secret-surfaces",
          "action": "preserve",
          "risk": "high",
          "ownership": "user_local",
          "paths": [
            "_ref/",
            ".codegraph/",
            "_ops/"
          ],
          "summary": "Never migrate, delete, or vendor ignored external references, local CodeGraph indexes, private operations state, secrets, or local environment values."
        }
      ]
    }
  }
}
