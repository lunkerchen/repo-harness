        "defaultProfile": "none",
        "recommendedProfiles": ["chat-agent", "product-copilot"]
      },
      "defaultHarnessProfiles": {
        "orchestration": "shared-long-running-harness",
        "evaluation": "browser-qa",
        "handoff": "artifact-aware",
        "recovery": "hybrid",
        "state": "file-backed"
      },
      "defaultLsp": "typescript-lsp",
      "defaultTemplateVariables": {
