{
  "version": "1.0.0",
  "contractId": "tasks-first-harness-v1",
  "compatibility": {
    "agents": ["claude", "codex"],
    "repoLocalFirst": true
  },
  "externalTooling": {
    "waza": {
      "sourceRepo": "tw93/Waza",
      "managedSkills": ["check", "design", "health", "hunt", "learn", "read", "think", "write"],
      "primaryHost": "codex",
      "codexPrimaryPath": "~/.codex/skills",
      "stagingCachePath": "~/.agents/skills",
      "syncMode": "stage-upstream-then-copy-to-codex",
      "hostDriftPolicy": "report-per-host-version-staging-and-upstream-drift"
    }
  },
  "agenticDevelopment": {
    "routing": {
      "productDiscovery": "gstack:office-hours",
      "complexEngineeringPlan": "gstack:plan-eng-review",
      "designPlan": "gstack:plan-design-review",
      "smallOrMediumPlan": "waza:think",
      "bugOrRegression": "waza:hunt",
      "postImplementationReview": "waza:check"
    },
    "dueDiligence": {
      "levels": ["P1_GLOBAL_ARCHITECTURE", "P2_DATA_FLOW_TRACE", "P3_DESIGN_DECISION"],
      "explicitReportRequiredFor": ["plan-eng-review", "hunt", "risky_refactor", "deployment", "auth_payment_data", "shared_contract"]
    }
  },
  "helpers": {
    "scripts": [
      "new-spec.sh",
      "new-sprint.sh",
      "new-plan.sh",
      "plan-to-todo.sh",
      "archive-workflow.sh",
      "prepare-handoff.sh",
      "verify-contract.sh",
      "summarize-failures.sh",
      "verify-sprint.sh",
      "check-task-sync.sh",
      "check-agent-tooling.sh",
      "check-context-files.sh",
      "ensure-task-workflow.sh",
      "check-task-workflow.sh",
      "maintenance-triage.sh",
      "switch-plan.sh",
      "context-budget.ts",
      "prepare-codex-handoff.sh",
      "codex-handoff-resume.sh"
    ]
  },
  "artifacts": {
    "runtimeManifest": ".ai/harness/workflow-contract.json",
    "requiredDirectories": [
      "plans",
      "plans/archive",
      "tasks",
      "tasks/archive",
      "tasks/contracts",
      "tasks/reviews",
      ".claude/templates",
      ".ai/context",
      ".ai/harness",
      ".ai/harness/checks",
      ".ai/harness/failures",
      ".ai/harness/handoff",
      ".ai/harness/context-budget",
      ".ai/harness/runs",
      "docs/reference-configs"
    ],
    "requiredFiles": [
      "docs/spec.md",
      ".claude/templates/spec.template.md",
      ".claude/templates/plan.template.md",
      ".claude/templates/research.template.md",
      ".claude/templates/contract.template.md",
      ".claude/templates/review.template.md",
      "scripts/new-spec.sh",
      "scripts/new-sprint.sh",
      "scripts/new-plan.sh",
      "scripts/plan-to-todo.sh",
      "scripts/archive-workflow.sh",
      "scripts/prepare-handoff.sh",
      "scripts/verify-contract.sh",
      "scripts/summarize-failures.sh",
      "scripts/verify-sprint.sh",
      "scripts/check-task-sync.sh",
      "scripts/check-agent-tooling.sh",
      "scripts/check-context-files.sh",
      "scripts/ensure-task-workflow.sh",
      "scripts/check-task-workflow.sh",
      "scripts/maintenance-triage.sh",
      "scripts/switch-plan.sh",
      "scripts/context-budget.ts",
      "scripts/prepare-codex-handoff.sh",
      "scripts/codex-handoff-resume.sh",
      "tasks/todo.md",
      "tasks/lessons.md",
      "tasks/research.md",
      "docs/PROGRESS.md",
      ".ai/context/context-map.json",
      ".ai/harness/policy.json",
      ".ai/harness/workflow-contract.json",
      "docs/reference-configs/agentic-development-flow.md",
      "docs/reference-configs/external-tooling.md"
    ],
    "runtimeFiles": [
      ".ai/harness/checks/latest.json",
      ".ai/harness/events.jsonl",
      ".ai/harness/failures/latest.jsonl",
      ".ai/harness/handoff/current.md",
      ".ai/harness/handoff/resume.md",
      ".ai/harness/context-budget/latest.json",
      ".ai/harness/runs/.gitkeep"
    ]
  },
  "documents": {
    "spec": "docs/spec.md",
    "planDirectory": "plans",
    "progressLedger": "docs/PROGRESS.md",
    "taskChecklist": "tasks/todo.md",
    "researchNotes": "tasks/research.md",
    "lessonsLog": "tasks/lessons.md"
  },
  "migrations": {
    "legacyVersions": [
      "pre-tasks-first",
      "tasks-first-without-contract-manifest",
      "current-v1"
    ],
    "legacyPaths": [
      "docs/plan.md",
      "docs/TODO.md",
      "docs/PROGRESS.md",
      "docs/contract.md",
      "docs/review.md",
      "docs/handoff.md",
      "HANDOFF.md"
    ]
  }
}
